{
  "name": "skillfish",
  "version": "0.1.0",
  "description": "Connect your Claude Code sessions to Skillfish skills via MCP. Syncs baseline skills to local filesystem and provides on-demand skill search.",
  "author": {
    "name": "Skillfish",
    "url": "https://skillfish.com"
  },
  "repository": "https://github.com/knoxgraeme/mcpmarket-plugin",
  "homepage": "https://skillfish.com",
  "license": "MIT",
  "keywords": ["skills", "mcp", "skillfish", "toolkit"],
  "skills": "./skills/",
  "mcpServers": "./.mcp.json",
  "userConfig": {
    "toolkit_url": {
      "title": "Toolkit MCP URL",
      "description": "Your Skillfish toolkit MCP URL (e.g., https://gateway.mcpmarket.com/my-org/toolkits/my-workspace/mcp)",
      "type": "string",
      "sensitive": false
    },
    "api_token": {
      "title": "API Token",
      "description": "Your Skillfish API token (sk_user_...)",
      "type": "string",
      "sensitive": true
    },
    "api_url": {
      "title": "API Base URL (optional)",
      "description": "Override the API base URL for local development (e.g., http://localhost:3000). Leave blank for production.",
      "type": "string",
      "sensitive": false
    }
  }
}
